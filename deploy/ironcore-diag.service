[Unit]
Description=Ironcore Diag Next.js App
After=network.target

[Service]
Type=simple
User=openclaw
WorkingDirectory=/home/openclaw/.openclaw/workspace/ironcore-diag
Environment=NODE_ENV=production
Environment=PORT=3011
EnvironmentFile=/etc/ironcore-diag.env
ExecStart=/usr/bin/npm run start -- --hostname 127.0.0.1 --port 3011
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
